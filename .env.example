# AI Provider: 'gemini' (FREE) or 'anthropic' (paid)
AI_PROVIDER=gemini

# Gemini API (FREE — get key from https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Claude API (paid fallback — only needed if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Google Search Console (OAuth2 service account)
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/google-service-account.json
SITE_URL=https://app.edpayu.com

# Replicate (Image Generation)
REPLICATE_API_TOKEN=r8_xxxxx

# Social Media APIs
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=

FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Website (for auto-publishing blog posts)
EDPAYU_BLOG_CMS=wordpress
WORDPRESS_URL=https://edpayu.com
WORDPRESS_USER=
WORDPRESS_APP_PASSWORD=

# Agent Config
CONTENT_LANGUAGE=en,hi
TARGET_REGION=India
DAILY_RUN_TIME=06:00
LOG_LEVEL=info
